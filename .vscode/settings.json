{
    "markdown.validate.enabled": true,
    "python.analysis.typeCheckingMode": "basic",

    "editor.formatOnSave": true,

    "[python]": {
        "editor.defaultFormatter": "ms-python.black-formatter"
    },
    "[markdown]": {
        "editor.defaultFormatter": "vscode.markdown-language-features"
    },

    "ruff.enable": true,
}